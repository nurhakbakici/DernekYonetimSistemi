# Kopyalayın: cp .env.example .env  (Windows: copy .env.example .env)
# Değerleri Firebase Console → Proje ayarları → Genel → Web uygulaması SDK snippet’ten alın.
# EXPO_PUBLIC_* değişkenleri Metro ile derlenir ve istemci paketine gömülür; güvenlik için Firestore kuralları ve App Check kullanın.

EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
# İsteğe bağlı (Analytics açıksa)
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firestore seed (npm run seed:firestore) — script .env dosyasını okur
SEED_ADMIN_EMAIL=admin@kulesakinleri.com
SEED_ADMIN_PASSWORD=admin123
# slug ile derneğe modül verisi (ör. YBS dernek → ybsder)
# SEED_DERNEK_SLUG=ybsder
# SEED_MEMBER_PASSWORD=Demo123!
# SEED_YBS_FORCE=1

# Virgülle ayrılmış Firebase Auth UID — dernek açılış başvurularını onaylama yetkisi (seed çıktısındaki admin UID)
EXPO_PUBLIC_PLATFORM_ADMIN_UIDS=
