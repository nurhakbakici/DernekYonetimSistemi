# Kopyalayın: copy .env.example .env
# Mobil uygulama ile aynı Firebase projesini kullanın (.env içindeki EXPO_PUBLIC_* değerleri).

VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Platform dernek onayı (virgülle ayrılmış e-postalar; Firestore kuralları ile uyumlu tutun)
VITE_PLATFORM_ADMIN_EMAILS=admin@kulesakinleri.com
